{
  "dangerouslySkipPermissions": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo stop > /workspace/.claude-notify"
          },
          {
            "type": "command",
            "command": "node /workspace/transcripts/sync-transcripts.js > /workspace/transcripts/.last-sync.log 2>&1 &"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo permission > /workspace/.claude-notify"
          }
        ]
      }
    ]
  }
}
