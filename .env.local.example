# CAX Web App Environment Variables
# Copy this file to .env.local and fill in values

# Set to "true" to use mock/fixture data instead of live APIs
USE_MOCK=true

# GitHub Personal Access Token (for Codespace provisioning)
# Only needed when USE_MOCK=false
GITHUB_PAT=

# GitHub org/user for Codespace provisioning
GITHUB_OWNER=

# Template repo for broken portfolio site
GITHUB_TEMPLATE_REPO=

# Claude API Key (for 4D AI Fluency scoring)
# Only needed when USE_MOCK=false
ANTHROPIC_API_KEY=
